--- a/app/src/keymap.c
+++ b/app/src/keymap.c
@@ -28,9 +28,65 @@ LOG_MODULE_DECLARE(zmk, CONFIG_ZMK_LOG_LEVEL);
 #include <drivers/behavior.h>
 #include "./behaviors/behavior_sensor_rotate_common.h"
 
+#include <zephyr/drivers/gpio.h>
+#if IS_ENABLED(CONFIG_SETTINGS)
+#include <zephyr/init.h>
+#include <zephyr/settings/settings.h>
+#endif
+
 static zmk_keymap_layers_state_t _zmk_keymap_layer_state = 0;
 static uint8_t _zmk_keymap_layer_default = 0;
 
+// --- Dwerty: Mac/Win slide + persisted Dvorak/Qwerty half ------------------
+// The default layer encodes two independent bits:
+//   bit1 (DWERTY_WIN_BIT) = OS half : 0 = Mac (layers 0/1), 1 = Windows (2/3)
+//   bit0                  = mode    : 0 = Qwerty base, 1 = Dvorak ("Dwerty")
+// Binding resolution keys off _zmk_keymap_layer_default (see
+// zmk_keymap_position_state_changed), so changing it re-bases typing at once.
+// The OS bit is driven live from the physical Mac/Win slide; only the mode bit
+// is persisted, so the slide always wins at boot. Fn+Z (&to DWERTY_TOGGLE)
+// flips the mode bit on whichever OS half is current. Mirrors QMK max.
+#define DWERTY_SETTING        "dwerty/mode"  // persisted mode bit (0/1)
+#define DWERTY_TOGGLE         0xFF           // &to sentinel: flip the mode bit
+#define DWERTY_WIN_BIT        0x2            // OS-half bit of the default layer
+#define DWERTY_SLIDE_POSITION 109           // Mac/Win slide = RC(6,0)
+
+// Mac/Win slide = input-gpios[0] of the direct kscan node (P3_2, ACTIVE_LOW).
+// Reading its logical level (1 = Win) derives the OS half deterministically at
+// boot and on every slide edge, rather than trusting a momentary overlay that a
+// marginal boot scan can miss (which left the board stuck on Mac).
+static const struct gpio_dt_spec dwerty_slide =
+    GPIO_DT_SPEC_GET_BY_IDX(DT_NODELABEL(kscan1), input_gpios, 0);
+
+static void dwerty_apply_slide(void) {
+    if (!device_is_ready(dwerty_slide.port)) {
+        return;
+    }
+    int win = gpio_pin_get_dt(&dwerty_slide);
+    if (win < 0) {
+        return;
+    }
+    WRITE_BIT(_zmk_keymap_layer_default, 1, win);
+}
+
+static int dwerty_slide_listener(const zmk_event_t *eh) {
+    const struct zmk_position_state_changed *ev = as_zmk_position_state_changed(eh);
+    if (ev != NULL && ev->position == DWERTY_SLIDE_POSITION) {
+        dwerty_apply_slide();
+    }
+    return ZMK_EV_EVENT_BUBBLE;
+}
+ZMK_LISTENER(dwerty_slide, dwerty_slide_listener);
+ZMK_SUBSCRIPTION(dwerty_slide, zmk_position_state_changed);
+
+#if IS_ENABLED(CONFIG_SETTINGS)
+static struct k_work_delayable dwerty_save_work;
+static void dwerty_save_work_handler(struct k_work *work) {
+    uint8_t mode = _zmk_keymap_layer_default & 1;
+    settings_save_one(DWERTY_SETTING, &mode, sizeof(mode));
+}
+#endif
+
 #define DT_DRV_COMPAT zmk_keymap
 
 #if !DT_NODE_EXISTS(DT_DRV_INST(0))
@@ -144,6 +200,17 @@ int zmk_keymap_layer_toggle(uint8_t layer) {
 };
 
 int zmk_keymap_layer_to(uint8_t layer) {
+    // Fn+Z sentinel: flip ONLY the Dvorak/Qwerty bit of the current default
+    // (0<->1, 2<->3), persist it, and leave the live slide OS half and any held
+    // layers intact. Binding resolution re-bases typing immediately.
+    if (layer == DWERTY_TOGGLE) {
+        _zmk_keymap_layer_default ^= 1;
+#if IS_ENABLED(CONFIG_SETTINGS)
+        k_work_reschedule(&dwerty_save_work, K_NO_WAIT);
+#endif
+        return 0;
+    }
+
     for (int i = ZMK_KEYMAP_LAYERS_LEN - 1; i >= 0; i--) {
         zmk_keymap_layer_deactivate(i);
     }
@@ -157,6 +224,39 @@ bool is_active_layer(uint8_t layer, zmk_keymap_layers_state_t layer_state) {
     return (layer_state & BIT(layer)) == BIT(layer) || layer == _zmk_keymap_layer_default;
 }
 
+// Restore the persisted Dwerty (Dvorak/Qwerty) mode bit on boot, then derive the
+// Mac/Win OS half from the physical slide so the switch is honoured immediately.
+#if IS_ENABLED(CONFIG_SETTINGS)
+static int dwerty_settings_load_cb(const char *name, size_t len, settings_read_cb read_cb,
+                                   void *cb_arg, void *param) {
+    const char *next;
+    if (settings_name_steq(name, "mode", &next) && !next) {
+        uint8_t mode;
+        if (len != sizeof(mode)) {
+            return -EINVAL;
+        }
+        int rc = read_cb(cb_arg, &mode, sizeof(mode));
+        if (rc >= 0) {
+            WRITE_BIT(_zmk_keymap_layer_default, 0, mode & 1);
+        }
+        return MIN(rc, 0);
+    }
+    return -ENOENT;
+}
+#endif
+
+static int dwerty_keymap_init(void) {
+    _zmk_keymap_layer_default = 1;  // default: Dvorak ("Dwerty"), Mac half
+#if IS_ENABLED(CONFIG_SETTINGS)
+    settings_subsys_init();
+    settings_load_subtree_direct("dwerty", dwerty_settings_load_cb, NULL);
+    k_work_init_delayable(&dwerty_save_work, dwerty_save_work_handler);
+#endif
+    dwerty_apply_slide();  // OS half from the physical Mac/Win slide
+    return 0;
+}
+SYS_INIT(dwerty_keymap_init, APPLICATION, CONFIG_APPLICATION_INIT_PRIORITY);
+
 const char *zmk_keymap_layer_name(uint8_t layer) {
     if (layer >= ZMK_KEYMAP_LAYERS_LEN) {
         return NULL;
