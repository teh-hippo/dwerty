/* Regression guard for the Mac/Win slide switch.
 *
 * The slide switch is a continuously-held GPIO that holds the matching Win
 * base (layer 1 here). Mirroring max/, that Win base is a FULL Dwerty base
 * with its own &dq_* morphs - not a transparent overlay - so typing the
 * Dvorak-Qwerty morph still fires on either OS half, and only the bottom-row
 * modifier order (Mac LALT <-> Win LGUI) changes. The original bug pointed the
 * switch at a non-transparent DVORAK layer, which silently disabled the morph.
 *
 * Matrix:
 *   (0,0) dq_j   - morph: Dvorak J normally, Qwerty C under Ctrl/Alt/GUI
 *   (0,1) LCTRL
 *   (1,0) mo 1   - the "slide switch": momentarily holds the Win Dwerty base
 *   (1,1) LALT (Mac) / LGUI (Win) - the Mac<->Win modifier swap
 */
/ {
    behaviors {
        dq_j: dvorak_qwerty_j {
            compatible = "zmk,behavior-mod-morph";
            #binding-cells = <0>;
            bindings = <&kp J>, <&kp C>;
            mods = <(MOD_LCTL|MOD_RCTL|MOD_LALT|MOD_RALT|MOD_LGUI|MOD_RGUI)>;
            keep-mods = <(MOD_LCTL|MOD_RCTL|MOD_LALT|MOD_RALT|MOD_LGUI|MOD_RGUI)>;
        };
    };

    keymap {
        compatible = "zmk,keymap";
        mac_dwerty {
            bindings = <
                &dq_j      &kp LCTRL
                &mo 1      &kp LALT
            >;
        };
        win_dwerty {
            /* full Dwerty base: same morph, only the modifier order is Win */
            bindings = <
                &dq_j      &kp LCTRL
                &trans     &kp LGUI
            >;
        };
    };
};
